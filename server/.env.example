# ═══════════════════════════════════════════════════════════════════
# PEOPLE PLATFORM - SERVER ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values
# NEVER commit .env to git!
# ═══════════════════════════════════════════════════════════════════

# ─── Core ───
NODE_ENV=development
PORT=5001

# ─── Firebase Admin SDK ───
# Get from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── Stripe (for Payments) ───
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Razorpay (India Payments) ───
# Get from: https://dashboard.razorpay.com/
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── Cloudinary ───
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Email (Support SMTP) ───
# Preferred provider: Postmark SMTP for transactional/auth email deliverability
POSTMARK_SERVER_TOKEN=
# Custom SMTP relay for support/auth email (leave blank if using Postmark defaults)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=PEOPLE Support
AUTH_EMAIL_REPLY_TO=
AUTH_EMAIL_DOMAIN=
SUPPORT_INBOX_EMAIL=
SUPPORT_REPLY_TO=
SUPPORT_OUTBOX_MAX_ATTEMPTS=5
SUPPORT_OUTBOX_BASE_DELAY_MS=30000
ADMIN_MESSAGES_ENABLED=true
ADMIN_PAYMENTS_CONSOLE_ENABLED=true
ADMIN_AUDIT_ENABLED=true
ADMIN_REQUIRE_MFA=false
ADMIN_MFA_ENFORCEMENT_MODE=warn
ADMIN_MFA_RESET_REQUIRE_REASON=true

# ─── Legacy Email (Optional) ───
# Keep only if still used in non-support paths
RESEND_API_KEY=
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ─── AI ───
GEMINI_API_KEY=

# ─── URLs ───
FRONTEND_URL=http://localhost:5173
