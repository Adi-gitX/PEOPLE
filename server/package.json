{
  "name": "people-server",
  "version": "1.0.0",
  "description": "PEOPLE Platform API Server",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "npm run check:system && tsx watch src/index.ts",
    "build": "tsc",
    "vercel-build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check:system": "tsx src/startup/preflight.ts",
    "smoke:postdeploy": "bash ../scripts/post-deploy-smoke.sh",
    "admin:bootstrap-profiles": "tsx src/scripts/backfillAdminProfiles.ts"
  },
  "keywords": [
    "people",
    "platform",
    "missions",
    "collaboration"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "firebase-admin": "^12.7.0",
    "nodemailer": "^7.0.12",
    "resend": "^2.1.0",
    "stripe": "^14.25.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.27",
    "@types/nodemailer": "^7.0.4",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
